<!-- Backdrop para versión móvil -->
<div class="sidebar-backdrop" id="sidebarBackdrop"></div>

<!-- ── SIDEBAR (Slack-style) ─────────────────────────────── -->
<nav class="sidebar" id="sidebar">
  <div style="flex: 1; overflow-y: auto; display: flex; flex-direction: column;">
    <!-- Workspace header -->
    <div class="sidebar-header" style="flex-shrink: 0; position: relative;">
      <button class="workspace-btn" id="workspaceBtn">
        <span class="workspace-name">SlacIA</span>
        <svg class="chevron-icon" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd"
            d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" />
        </svg>
      </button>

      <!-- Menu Workspace / Admin -->
      <div class="profile-dropdown" id="workspaceDropdown" style="display: none; top: 100%; left: 16px;">
        <div class="dropdown-item" id="btnConfiguracion">
          <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" style="margin-right: 8px;">
            <path fill-rule="evenodd"
              d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z"
              clip-rule="evenodd" />
          </svg>
          Configuración
        </div>
      </div>

      <button class="new-msg-btn" title="Nuevo mensaje" id="btnNuevoMensaje">
        <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
          <path
            d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 010 2H4a1 1 0 01-1-1zM3 16a1 1 0 011-1h6a1 1 0 010 2H4a1 1 0 01-1-1z" />
        </svg>
      </button>
    </div>

    <!-- Search -->
    <div class="sidebar-search">
      <button class="search-btn" id="searchBtn">
        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
          <path fill-rule="evenodd"
            d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" />
        </svg>
        Buscar en SlacIA
      </button>
    </div>

    <!-- Nav items -->
    <div class="sidebar-nav">
      <a class="sidebar-nav-item" href="#">
        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
          <path
            d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" />
        </svg>
        Actividad
      </a>
      <a class="sidebar-nav-item" href="#">
        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
          <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
          <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
        </svg>
        Mensajes directos
      </a>
      <a class="sidebar-nav-item" href="#">
        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
          <path fill-rule="evenodd"
            d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" />
        </svg>
        Más tarde
      </a>
    </div>

    <!-- Channels section -->
    <div class="sidebar-section">
      <div class="sidebar-section-header" id="toggleChannels">
        <svg class="section-arrow open" viewBox="0 0 20 20" fill="currentColor" width="12" height="12">
          <path fill-rule="evenodd"
            d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" />
        </svg>
        Canales
        <button class="add-section-btn" title="Agregar canal">+</button>
      </div>
      <ul class="channel-list" id="channelList">
        <li class="channel-item active" data-channel="general">
          <span class="channel-hash">#</span> general
        </li>
        <li class="channel-item" data-channel="desarrollo">
          <span class="channel-hash">#</span> desarrollo
          <span class="badge">3</span>
        </li>
        <li class="channel-item" data-channel="diseno">
          <span class="channel-hash">#</span> diseño
        </li>
        <li class="channel-item" data-channel="random">
          <span class="channel-hash">#</span> random
        </li>
        <li class="channel-item add-channel" id="btnAgregarCanal">
          <span class="channel-plus">+</span> Agregar canal
        </li>
      </ul>
    </div>

    <!-- Directorio de Usuarios -->
    <div class="sidebar-section">
      <div class="sidebar-section-header" id="toggleUsers" style="cursor: pointer;">
        <svg class="section-arrow open" viewBox="0 0 20 20" fill="currentColor" width="12" height="12">
          <path fill-rule="evenodd"
            d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" />
        </svg>
        Directorio (Clic para chatear)
      </div>
      <ul class="dm-list" id="usersList">
        <!-- Usuarios cargados dinámicamente -->
      </ul>
    </div>
  </div> <!-- /Fin scrollable -->

  <!-- Botón de Perfil & Menú (Bottom Sidebar) -->
  <div class="profile-menu-container"
    style="flex-shrink: 0; position: relative; margin-top: auto; padding: 12px 16px; border-top: 1px solid rgba(255,255,255,0.08);">
    <button class="profile-avatar-btn" id="btnProfile" title="Ver perfil y configuración"
      style="width: 100%; display: flex; align-items: center; justify-content: flex-start; gap: 10px; background: transparent; padding: 8px; border-radius: 6px;">
      <span class="dm-avatar" id="profileInitials" style="background:#3B82F6">U</span>
      <span id="profileNameDisplay"
        style="color: var(--slack-text); font-weight: 700; font-size: 14px;">Usuario</span>
    </button>

    <div class="profile-dropdown" id="profileDropdown"
      style="display: none; bottom: 50px; left: 16px; top: auto; right: auto;">
      <div class="profile-dropdown-header">
        <div class="profile-dropdown-avatar" id="dropdownAvatar">U</div>
        <div class="profile-dropdown-info">
          <div class="profile-dropdown-name" id="dropdownName">Usuario</div>
          <div class="profile-dropdown-status"><span class="conn-dot online" style="animation:none;"></span> Activo
          </div>
        </div>
      </div>
      <div class="profile-dropdown-divider"></div>
      <div class="profile-dropdown-item theme-switch-item"
        style="display:flex; justify-content:space-between; align-items:center; padding: 10px 14px;">
        <span style="font-size:13px; font-weight:600; color:var(--text-main);">Modo Oscuro</span>
        <label class="n8n-switch" style="width:34px; height:18px;">
          <input type="checkbox" id="themeDarkSwitch" />
          <span class="n8n-slider"></span>
        </label>
      </div>
      <div class="profile-dropdown-divider"></div>
      <button class="profile-dropdown-item-btn" id="btnChangeUser"
        style="width:100%; text-align:left; background:none; border:none; padding:10px 14px; font-size:13px; color:var(--text-main); font-weight:500; cursor:pointer;">Cambiar
        Nombre</button>
    </div>
  </div>
</nav>
